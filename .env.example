# ============================================
# Lansy.ai — Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key
SUPABASE_JWT_SECRET=your-jwt-secret

# --- Google Gemini ---
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/lansy

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- ChromaDB ---
CHROMADB_HOST=localhost
CHROMADB_PORT=8001

# --- Konnect Payment (Tunisia) ---
KONNECT_API_URL=https://api.konnect.network/api/v2
KONNECT_API_KEY=your-konnect-key
KONNECT_WALLET_ID=your-wallet-id

# --- App ---
SECRET_KEY=your-secret-key-minimum-32-characters-long
FRONTEND_URL=http://localhost:3000
